{
  "title": "Rate Limiter Skripsi",
  "uid": "rate-limiter-skripsi",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (200 vs 429) - Token Bucket",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=\"200\",endpoint=~\"/api/login|/api/data\"}[30s])",
          "legendFormat": "200 OK - {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "rate(http_requests_total{status=\"429\",endpoint=~\"/api/login|/api/data\"}[30s])",
          "legendFormat": "429 Blocked - {{endpoint}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "429.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "200.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Request Diblok per Detik - Token Bucket",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "targets": [
        {
          "expr": "rate(rate_limit_blocked_total{endpoint=~\"/api/login|/api/data\"}[30s])",
          "legendFormat": "Blocked - {{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 3,
      "title": "200 vs 429 Total - Token Bucket",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "targets": [
        {
          "expr": "sum(http_requests_total{status=\"200\",endpoint=~\"/api/login|/api/data\"})",
          "legendFormat": "200 OK",
          "refId": "A"
        },
        {
          "expr": "sum(http_requests_total{status=\"429\",endpoint=~\"/api/login|/api/data\"})",
          "legendFormat": "429 Blocked",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "429 Blocked"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "200 OK"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "TB vs SW - Request Rate (login vs login-sw)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "description": "Perbandingan request rate Token Bucket vs Sliding Window pada endpoint login",
      "targets": [
        {
          "expr": "rate(http_requests_total{status=\"200\",endpoint=\"/api/login\"}[30s])",
          "legendFormat": "TB - 200 OK",
          "refId": "A"
        },
        {
          "expr": "rate(http_requests_total{status=\"429\",endpoint=\"/api/login\"}[30s])",
          "legendFormat": "TB - 429 Blocked",
          "refId": "B"
        },
        {
          "expr": "rate(http_requests_total{status=\"200\",endpoint=\"/api/login-sw\"}[30s])",
          "legendFormat": "SW - 200 OK",
          "refId": "C"
        },
        {
          "expr": "rate(http_requests_total{status=\"429\",endpoint=\"/api/login-sw\"}[30s])",
          "legendFormat": "SW - 429 Blocked",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "TB.*200.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "TB.*429.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "SW.*200.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "SW.*429.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "TB vs SW - Blocked Rate (login vs login-sw)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "description": "Perbandingan jumlah request yang diblok Token Bucket vs Sliding Window",
      "targets": [
        {
          "expr": "rate(rate_limit_blocked_total{endpoint=\"/api/login\"}[30s])",
          "legendFormat": "Token Bucket blocked",
          "refId": "A"
        },
        {
          "expr": "rate(rate_limit_blocked_total{endpoint=\"/api/login-sw\"}[30s])",
          "legendFormat": "Sliding Window blocked",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Token Bucket blocked"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Sliding Window blocked"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "CPU Usage - rate-limiter-app (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "description": "CPU usage container app dalam persen",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=\"rate-limiter-app\"}[30s]) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": {
            "fixedColor": "yellow",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Memory Usage - rate-limiter-app (MB)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "description": "RAM yang dipakai container app",
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=\"rate-limiter-app\"} / 1024 / 1024",
          "legendFormat": "RAM (MB)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Resource Saat Ini - rate-limiter-app",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "description": "Snapshot CPU dan RAM saat ini",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=\"rate-limiter-app\"}[30s]) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        },
        {
          "expr": "container_memory_usage_bytes{name=\"rate-limiter-app\"} / 1024 / 1024",
          "legendFormat": "RAM MB",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "CPU %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "RAM MB"
            },
            "properties": [
              {
                "id": "unit",
                "value": "decmbytes"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    }
  ]
}